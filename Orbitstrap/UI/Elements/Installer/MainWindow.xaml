<?xml version="1.0" encoding="utf-8"?>
<base:WpfUiWindow x:Class="Orbitstrap.UI.Elements.Installer.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:pages="clr-namespace:Orbitstrap.UI.Elements.Installer.Pages" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:base="clr-namespace:Orbitstrap.UI.Elements.Base" xmlns:resources="clr-namespace:Orbitstrap.Resources" xmlns:dmodels="clr-namespace:Orbitstrap.UI.ViewModels.Installer" xmlns:local="clr-namespace:Orbitstrap.UI.Elements.Installer" Title="{x:Static resources:Strings.Installer_Title}" Height="540" Width="840" MinWidth="840" ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowStartupLocation="CenterScreen" Background="{ui:ThemeResource ApplicationBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ui:TitleBar Name="RootTitleBar" Padding="8" Grid.Row="0" ForceShutdown="False" MinimizeToTray="False" UseSnapLayout="True" Title="{x:Static resources:Strings.Installer_Title}" Icon="pack://application:,,,/Orbitstrap.ico" />
    <Grid Name="RootGrid" Row="1" Margin="12,12,0,0" Visibility="Visible">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="200" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <ui:NavigationFluent Name="RootNavigation" Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" SelectedPageIndex="0" IsEnabled="False" Frame="{Binding ElementName=RootFrame}">
        <ui:NavigationBase.Items>
          <ui:NavigationItem Content="{x:Static resources:Strings.Installer_Welcome_Title}" Icon="ArrowCircleRight24" PageType="{x:Type pages:WelcomePage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Installer_Install_Title}" Icon="ArrowCircleRight24" PageType="{x:Type pages:InstallPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Installer_Completion_Title}" Icon="ArrowCircleRight24" PageType="{x:Type pages:CompletionPage}" />
        </ui:NavigationBase.Items>
      </ui:NavigationFluent>
      <Grid Row="0" RowSpan="2" Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:Breadcrumb Grid.Row="0" Margin="0,0,0,5" Navigation="{Binding ElementName=RootNavigation}" />
        <Frame Name="RootFrame" Grid.Row="1" />
      </Grid>
    </Grid>
    <StatusBar Name="RootStatusBar" Grid.Row="2" Padding="14,10" BorderThickness="0,1,0,0" Background="{ui:ThemeResource ApplicationBackgroundBrush}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
          </Grid>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <StatusBarItem Grid.Column="1" Padding="0,0,4,0">
        <ui:Button Content="{x:Static resources:Strings.Common_Navigation_Back}" Width="{Binding ButtonWidth, Mode=OneTime}" Command="{Binding BackPageCommand, Mode=OneWay}" IsEnabled="{Binding BackButtonEnabled, Mode=OneWay}" />
      </StatusBarItem>
      <StatusBarItem Grid.Column="2" Padding="4,0,4,0">
        <ui:Button Name="NextButton" IsEnabled="True" Content="{Binding NextButtonText, Mode=OneWay}" Width="{Binding ButtonWidth, Mode=OneTime}" Command="{Binding NextPageCommand, Mode=OneWay}" />
      </StatusBarItem>
      <StatusBarItem Grid.Column="3" Padding="12,0,0,0">
        <ui:Button Content="{x:Static resources:Strings.Common_Close}" Width="{Binding ButtonWidth, Mode=OneTime}" Command="{Binding CloseWindowCommand, Mode=OneWay}" />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</base:WpfUiWindow>