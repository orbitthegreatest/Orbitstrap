<?xml version="1.0" encoding="utf-8"?>
<ui:UiPage x:Class="Orbitstrap.UI.Elements.About.Pages.SupportersPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:models="clr-namespace:Orbitstrap.UI.ViewModels" xmlns:controls="clr-namespace:Orbitstrap.UI.Elements.Controls" xmlns:enums="clr-namespace:Orbitstrap.Enums" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:resources="clr-namespace:Orbitstrap.Resources" Title="AboutPage" Scrollable="True" xmlns:pages="clr-namespace:Orbitstrap.UI.Elements.About.Pages" SizeChanged="UiPage_SizeChanged">
  <StackPanel Margin="0,0,14,14">
    <TextBlock Text="{x:Static resources:Strings.About_Supporters_Title}" FontWeight="Medium" FontSize="24" />
    <controls:MarkdownTextBlock MarkdownText="{x:Static resources:Strings.About_Supporters_Description}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
    <Grid Margin="0,8,0,0">
      <FrameworkElement.Style>
        <Style TargetType="{x:Type Grid}">
          <Style.Triggers>
            <DataTrigger Value="{x:Static enums:GenericTriState.Unknown}" Binding="{Binding LoadedState, Mode=OneWay}">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
          <Setter Property="Visibility" Value="Collapsed" />
        </Style>
      </FrameworkElement.Style>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <ui:ProgressRing Grid.Column="0" IsIndeterminate="True" />
      <TextBlock Grid.Column="1" Margin="16,0,0,0" Text="{x:Static resources:Strings.Common_Loading}" VerticalAlignment="Center" />
    </Grid>
    <Grid Margin="0,8,0,0">
      <FrameworkElement.Style>
        <Style TargetType="{x:Type Grid}">
          <Style.Triggers>
            <DataTrigger Value="{x:Static enums:GenericTriState.Failed}" Binding="{Binding LoadedState, Mode=OneWay}">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
          <Setter Property="Visibility" Value="Collapsed" />
        </Style>
      </FrameworkElement.Style>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Image Source="pack://application:,,,/Resources/MessageBox/Error.png" Width="60" Height="60" RenderOptions.BitmapScalingMode="HighQuality" />
      <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{x:Static resources:Strings.Common_NetworkError}" />
        <TextBlock Text="{Binding LoadError, Mode=OneWay}" />
      </StackPanel>
    </Grid>
    <StackPanel>
      <FrameworkElement.Style>
        <Style TargetType="{x:Type StackPanel}">
          <Style.Triggers>
            <DataTrigger Value="{x:Static enums:GenericTriState.Successful}" Binding="{Binding LoadedState, Mode=OneWay}">
              <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
          </Style.Triggers>
          <Setter Property="Visibility" Value="Collapsed" />
        </Style>
      </FrameworkElement.Style>
      <TextBlock Text="{x:Static resources:Strings.About_Supporters_Monthly}" FontWeight="Medium" FontSize="20" Margin="0,16,0,0" />
      <ListView Margin="0,8,0,0" ScrollViewer.CanContentScroll="False" IsEnabled="False" ItemsSource="{Binding SupporterData.Monthly.Supporters, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Padding="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Height="32" Width="32" VerticalAlignment="Center">
                  <Shape.Fill>
                    <ImageBrush ImageSource="{Binding Image, IsAsync=True}" />
                  </Shape.Fill>
                </Ellipse>
                <TextBlock Grid.Column="1" Margin="8,0,2,0" VerticalAlignment="Center" Text="{Binding Name}" />
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Margin="-4" Columns="{Binding Columns}" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ListView>
      <TextBlock Text="{x:Static resources:Strings.About_Supporters_OneOff}" FontWeight="Medium" FontSize="20" Margin="0,16,0,0" />
      <ListView Margin="0,8,0,0" ScrollViewer.CanContentScroll="False" IsEnabled="False" ItemsSource="{Binding SupporterData.OneOff.Supporters, Mode=OneWay}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <ui:Card Padding="8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" Height="32" Width="32" VerticalAlignment="Center">
                  <Shape.Fill>
                    <ImageBrush ImageSource="{Binding Image, IsAsync=True}" />
                  </Shape.Fill>
                </Ellipse>
                <TextBlock Grid.Column="1" Margin="8,0,2,0" VerticalAlignment="Center" Text="{Binding Name}" />
              </Grid>
            </ui:Card>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Margin="-4" Columns="{Binding Columns}" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ListView>
    </StackPanel>
  </StackPanel>
</ui:UiPage>