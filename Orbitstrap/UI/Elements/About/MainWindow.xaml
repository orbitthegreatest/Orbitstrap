<?xml version="1.0" encoding="utf-8"?>
<base:WpfUiWindow x:Class="Orbitstrap.UI.Elements.About.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:pages="clr-namespace:Orbitstrap.UI.Elements.About.Pages" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:base="clr-namespace:Orbitstrap.UI.Elements.Base" xmlns:resources="clr-namespace:Orbitstrap.Resources" Title="{x:Static resources:Strings.About_Title}" MinWidth="800" Width="800" Height="440" ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowStartupLocation="CenterScreen" xmlns:about="clr-namespace:Orbitstrap.UI.Elements.About" Background="{ui:ThemeResource ApplicationBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <ui:TitleBar Name="RootTitleBar" Padding="8" Grid.Row="0" ForceShutdown="False" MinimizeToTray="False" UseSnapLayout="True" Title="{x:Static resources:Strings.About_Title}" Icon="pack://application:,,,/Orbitstrap.ico" />
    <Grid Name="RootGrid" Row="1" Margin="12,12,0,0" Visibility="Visible">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <ui:NavigationStore Name="RootNavigation" Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" SelectedPageIndex="0" Frame="{Binding ElementName=RootFrame}">
        <ui:NavigationBase.Items>
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_About_Title}" Icon="QuestionCircle24" Tag="about" Margin="0,0,0,12" PageType="{x:Type pages:AboutPage}" />
          <ui:NavigationItem Visibility="Collapsed" Content="{x:Static resources:Strings.About_Supporters_Title}" Icon="Heart24" Tag="translators" Margin="0,0,0,12" PageType="{x:Type pages:SupportersPage}" />
          <ui:NavigationItem Icon="Translate24" Tag="translators" Margin="0,0,0,12" PageType="{x:Type pages:TranslatorsPage}">
            <TextBlock Name="TranslatorsText" Text="{x:Static resources:Strings.About_Translators_Title}" FontSize="10" />
          </ui:NavigationItem>
          <ui:NavigationItem Content="{x:Static resources:Strings.About_Licenses_Title}" Icon="Code24" Tag="licenses" Margin="0,0,0,12" PageType="{x:Type pages:LicensesPage}" />
        </ui:NavigationBase.Items>
      </ui:NavigationStore>
      <Frame Name="RootFrame" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" />
    </Grid>
  </Grid>
</base:WpfUiWindow>