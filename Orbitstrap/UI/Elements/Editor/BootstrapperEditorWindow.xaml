<?xml version="1.0" encoding="utf-8"?>
<base:WpfUiWindow x:Class="Orbitstrap.UI.Elements.Editor.BootstrapperEditorWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit" xmlns:base="clr-namespace:Orbitstrap.UI.Elements.Base" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:dmodels="clr-namespace:Orbitstrap.UI.ViewModels.Editor" xmlns:local="clr-namespace:Orbitstrap.UI.Elements.Editor" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:resources="clr-namespace:Orbitstrap.Resources" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" Closing="OnClosing" Width="1000" Height="500" ExtendsContentIntoTitleBar="True" WindowStartupLocation="CenterScreen" Title="{Binding Path=Title, Mode=OneTime}" Background="{ui:ThemeResource ApplicationBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ui:TitleBar Name="RootTitleBar" Grid.Row="0" Padding="8" ForceShutdown="False" Icon="pack://application:,,,/Orbitstrap.ico" MinimizeToTray="False" UseSnapLayout="True" Title="{Binding Path=Title, Mode=OneTime}" />
    <avalonedit:TextEditor Name="UIXML" Grid.Row="1" Margin="10,10,10,0" ShowLineNumbers="True" Style="{StaticResource NewTextEditor}" SyntaxHighlighting="XML" />
    <ui:Button Grid.Row="2" Margin="10" Content="{x:Static resources:Strings.CustomTheme_Editor_OpenThemeDirectory}" Command="{Binding Path=OpenThemeFolderCommand, Mode=OneTime}" />
    <Grid Row="2" Margin="10" HorizontalAlignment="Right">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <ui:Button Grid.Column="0" Margin="0,0,4,0" Content="{x:Static resources:Strings.CustomTheme_Editor_Preview}" Command="{Binding Path=PreviewCommand, Mode=OneTime}" />
      <ui:Button Grid.Column="1" Margin="4,0,0,0" Appearance="Primary" Content="{x:Static resources:Strings.CustomTheme_Editor_Save}" Command="{Binding Path=SaveCommand, Mode=OneTime}" />
    </Grid>
    <ui:Snackbar Name="Snackbar" Grid.RowSpan="3" Margin="200,0,200,20" Panel.ZIndex="9" Timeout="3000" />
  </Grid>
</base:WpfUiWindow>