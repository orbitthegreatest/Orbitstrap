<?xml version="1.0" encoding="utf-8"?>
<base:WpfUiWindow x:Class="Orbitstrap.UI.Elements.Settings.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:pages="clr-namespace:Orbitstrap.UI.Elements.Settings.Pages" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" xmlns:base="clr-namespace:Orbitstrap.UI.Elements.Base" xmlns:resources="clr-namespace:Orbitstrap.Resources" xmlns:dmodels="clr-namespace:Orbitstrap.UI.ViewModels.Settings" Closing="WpfUiWindow_Closing" Closed="WpfUiWindow_Closed" Title="{x:Static resources:Strings.Menu_Title}" MinWidth="1000" Width="1000" Height="580" ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" WindowStartupLocation="CenterScreen" xmlns:settings="clr-namespace:Orbitstrap.UI.Elements.Settings" Background="{ui:ThemeResource ApplicationBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ui:Snackbar Name="AlreadyRunningSnackbar" Title="{x:Static resources:Strings.Menu_AlreadyRunning_Title}" Message="{x:Static resources:Strings.Menu_AlreadyRunning_Caption}" Icon="Info20" Timeout="10000" Margin="200,0,200,20" Grid.RowSpan="10" Panel.ZIndex="10" />
    <ui:Snackbar Name="SettingsSavedSnackbar" Title="{x:Static resources:Strings.Menu_SettingsSaved_Title}" Message="{x:Static resources:Strings.Menu_SettingsSaved_Message}" Appearance="Success" Icon="CheckmarkCircle24" Timeout="3000" Margin="200,0,200,20" Grid.RowSpan="10" Panel.ZIndex="9" />
    <ui:TitleBar Name="RootTitleBar" Padding="8" Grid.Row="0" ForceShutdown="False" MinimizeToTray="False" UseSnapLayout="True" Title="{x:Static resources:Strings.Menu_Title}" Icon="pack://application:,,,/Orbitstrap.ico" />
    <Grid Name="RootGrid" Row="1" Margin="12,12,0,0" Visibility="Visible">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <ui:NavigationFluent Name="RootNavigation" Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" SelectedPageIndex="0" Frame="{Binding ElementName=RootFrame}">
        <ui:NavigationBase.Items>
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_Integrations_Title}" Icon="Add24" Tag="integrations" PageType="{x:Type pages:IntegrationsPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_Behaviour_Title}" Icon="Settings20" Tag="bootstrapper" PageType="{x:Type pages:BehaviourPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Common_Deployment}" Icon="Cloud24" Tag="channel" PageType="{x:Type pages:ChannelPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_Mods_Title}" Icon="Wrench24" Tag="mods" PageType="{x:Type pages:ModsPage}" />
          <ui:NavigationItem Name="fastflags" Content="{x:Static resources:Strings.Menu_FastFlags_Title}" Icon="Flag24" Tag="fastflags" PageType="{x:Type pages:FastFlagsPage}" />
          <ui:NavigationItem Name="gbs" Content="{x:Static resources:Strings.Common_GlobalSettings}" Icon="Settings20" Tag="gbseditor" PageType="{x:Type pages:GBSEditorPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_Appearance_Title}" Icon="PaintBrush24" Tag="appearance" PageType="{x:Type pages:AppearancePage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Common_Shortcuts}" Icon="Apps24" Tag="shortcuts" PageType="{x:Type pages:ShortcutsPage}" />
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_FastFlagEditor_Title}" Tag="fastflageditor" Visibility="Collapsed" PageType="{x:Type pages:FastFlagEditorPage}" />
                  <ui:NavigationItem Content="Extensions" Icon="Apps24" Tag="extensions" PageType="{x:Type pages:ExtensionPage}" />
          </ui:NavigationBase.Items>
        <ui:NavigationBase.Footer>
          <ui:NavigationItem Content="{x:Static resources:Strings.Menu_About_Title}" Icon="Info24" Margin="0,0,0,12" Command="{Binding OpenAboutCommand, Mode=OneTime}" />
        </ui:NavigationBase.Footer>
      </ui:NavigationFluent>
      <Grid Row="0" RowSpan="2" Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:InfoBar Name="AlertBar" Grid.Row="0" Margin="0,0,12,0" Padding="8" Visibility="Collapsed" IsOpen="True" Message="" Severity="Warning" IsClosable="False" />
        <ui:Breadcrumb Grid.Row="1" Margin="0,0,0,5" Navigation="{Binding ElementName=RootNavigation}" />
        <Frame Name="RootFrame" Grid.Row="2" />
      </Grid>
    </Grid>
    <StatusBar Name="RootStatusBar" Grid.Row="2" Padding="14,10" BorderThickness="0,1,0,0">
      <Control.Background>
        <SolidColorBrush Opacity="0" Color="{ui:ThemeResource ApplicationBackgroundColor}" />
      </Control.Background>
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
          </Grid>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <StatusBarItem Grid.Column="0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ui:ToggleSwitch IsChecked="{Binding TestModeEnabled, Mode=TwoWay}" />
          <TextBlock Padding="12,0,0,0" Text="{x:Static resources:Strings.Menu_TestMode}" VerticalAlignment="Center" FontSize="14" />
        </StackPanel>
      </StatusBarItem>
      <StatusBarItem Grid.Column="2" Padding="0,0,4,0">
        <ui:Button Content="{x:Static resources:Strings.Menu_SaveAndLaunch}" Appearance="Primary" Command="{Binding SaveAndLaunchSettingsCommand, Mode=OneWay}" />
      </StatusBarItem>
      <StatusBarItem Grid.Column="3" Padding="0,0,4,0">
        <ui:Button Content="{x:Static resources:Strings.Menu_Save}" Appearance="Primary" Command="{Binding SaveSettingsCommand, Mode=OneWay}" />
      </StatusBarItem>
      <StatusBarItem Grid.Column="4" Padding="0,0,0,0">
        <ui:Button Content="{x:Static resources:Strings.Common_Close}" Command="{Binding CloseWindowCommand, Mode=OneWay}" />
      </StatusBarItem>
    </StatusBar>
  </Grid>
</base:WpfUiWindow>