<?xml version="1.0" encoding="utf-8"?>
<!-- Orbitstrap Red & Black Theme -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Text Editor ──────────────────────────────────── -->
    <SolidColorBrush x:Key="NewTextEditorBackground" Color="#0D0000"/>
    <SolidColorBrush x:Key="NewTextEditorForeground" Color="#CC3333"/>
    <SolidColorBrush x:Key="NewTextEditorLink"       Color="#FF2222"/>

    <!-- ── Window Backgrounds ───────────────────────────── -->
    <Color x:Key="WindowBackgroundColorPrimary"                 >#1A0000</Color>
    <Color x:Key="WindowBackgroundColorSecondary"               >#100000</Color>
    <Color x:Key="WindowBackgroundColorTertiary"                >#080000</Color>
    <Color x:Key="WindowBackgroundColorPrimaryWithOpacity"      >#801A0000</Color>
    <Color x:Key="WindowBackgroundColorSecondaryWithOpacity"    >#80100000</Color>
    <Color x:Key="WindowBackgroundColorTertiaryWithOpacity"     >#80080000</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrushPrimary"   Color="{StaticResource WindowBackgroundColorPrimary}"   />
    <SolidColorBrush x:Key="WindowBackgroundBrushSecondary" Color="{StaticResource WindowBackgroundColorSecondary}" />
    <SolidColorBrush x:Key="WindowBackgroundBrushTertiary"  Color="{StaticResource WindowBackgroundColorTertiary}"  />

    <!-- ── Accent / Brand ───────────────────────────────── -->
    <Color x:Key="SystemAccentColor"         >#CC0000</Color>
    <Color x:Key="SystemAccentColorSecondary">#FF2222</Color>
    <Color x:Key="SystemAccentColorTertiary" >#FF5555</Color>

    <SolidColorBrush x:Key="SystemAccentBrush"         Color="#CC0000"/>
    <SolidColorBrush x:Key="AccentColorSecondaryBrush" Color="#FF2222"/>
    <SolidColorBrush x:Key="AccentColorTertiaryBrush"  Color="#FF5555"/>

    <!-- ── Surfaces ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="CardBackgroundBrush"        Color="#150000"/>
    <SolidColorBrush x:Key="CardBorderBrush"            Color="#3D1A0000"/>
    <SolidColorBrush x:Key="ControlFillColorBrush"      Color="#200000"/>

    <!-- ── Text ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush"   Color="#FF6666"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#CC4444"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush"  Color="#993333"/>

    <!-- ── Progress ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="ProgressBarForegroundBrush" Color="#CC0000"/>

</ResourceDictionary>
