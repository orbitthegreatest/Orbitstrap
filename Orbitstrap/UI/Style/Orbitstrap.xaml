<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Orbitstrap Theme — Matte Dark + Light Crimson-Red Accent
         Deep charcoal-black background, vivid rose-red accents,
         warm near-white text. Smooth glass-card surfaces.
    ============================================================ -->

    <!-- Text editor -->
    <SolidColorBrush x:Key="TextEditorBackgroundBrush"     Color="#0E0608"/>
    <SolidColorBrush x:Key="TextEditorForegroundBrush"     Color="#F2E8EA"/>
    <SolidColorBrush x:Key="TextEditorLinkBrush"           Color="#FF4D6A"/>
    <SolidColorBrush x:Key="NewTextEditorBackground"       Color="#990E0608"/>
    <SolidColorBrush x:Key="NewTextEditorForeground"       Color="#F2E8EA"/>
    <SolidColorBrush x:Key="NewTextEditorLink"             Color="#FF6B82"/>

    <!-- Background hierarchy — very dark, subtle warm tint -->
    <SolidColorBrush x:Key="PrimaryBackgroundColor"        Color="#0E0608"/>
    <SolidColorBrush x:Key="PrimaryBackgroundBrush"        Color="#0E0608"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush"      Color="#1A0C10"/>
    <SolidColorBrush x:Key="TertiaryBackgroundBrush"       Color="#08030A"/>
    <SolidColorBrush x:Key="NormalDarkAndLightBackground"  Color="#160A0E"/>

    <!-- Window gradient -->
    <Color x:Key="ControlFillColorDefault">#CC130810</Color>
    <Color x:Key="ControlFillColor">#130810</Color>
    <Color x:Key="WindowBackgroundColorPrimary">#0F0508</Color>
    <Color x:Key="WindowBackgroundColorSecondary">#1C0A10</Color>
    <Color x:Key="WindowBackgroundColorThird">#0C0407</Color>
    <Color x:Key="WindowBackgroundColorTertiary">#080205</Color>
    <Color x:Key="WindowBackgroundColorPrimaryWithOpacity">#CC0F0508</Color>
    <Color x:Key="WindowBackgroundColorSecondaryWithOpacity">#CC1C0A10</Color>
    <Color x:Key="WindowBackgroundColorTertiaryWithOpacity">#CC080205</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrushPrimary"   Color="{StaticResource WindowBackgroundColorPrimary}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrushSecondary" Color="{StaticResource WindowBackgroundColorSecondary}"/>
    <SolidColorBrush x:Key="WindowBackgroundBrushTertiary"  Color="{StaticResource WindowBackgroundColorTertiary}"/>

    <!-- Accent — vivid light crimson / rose-red -->
    <Color x:Key="SystemAccentColor">#E8284A</Color>
    <Color x:Key="SystemAccentColorPrimary">#E8284A</Color>
    <Color x:Key="SystemAccentColorSecondary">#C01835</Color>
    <Color x:Key="SystemAccentColorTertiary">#FF5573</Color>

    <SolidColorBrush x:Key="AccentBrush"          Color="#E8284A"/>
    <SolidColorBrush x:Key="AccentBrushPrimary"   Color="#E8284A"/>
    <SolidColorBrush x:Key="AccentBrushSecondary" Color="#C01835"/>
    <SolidColorBrush x:Key="SystemAccentBrush"    Color="#E8284A"/>

    <!-- Foreground — warm near-white -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush"   Color="#F5ECEE"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#C4ACAF"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush"  Color="#7A5F63"/>

    <!-- Card surfaces -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1A0D11"/>
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#2E1018"/>
    <SolidColorBrush x:Key="HoverBrush"          Color="#26E8284A"/>
    <SolidColorBrush x:Key="SelectionBrush"      Color="#40E8284A"/>
    <SolidColorBrush x:Key="NavSelectedBrush"    Color="#33E8284A"/>
    <SolidColorBrush x:Key="SeparatorBrush"      Color="#1EFFFFFF"/>

</ResourceDictionary>
