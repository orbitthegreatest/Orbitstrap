<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<DebugType>none</DebugType>
		<DebugSymbols>false</DebugSymbols>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>True</UseWindowsForms>
		<ApplicationIcon>Orbitstrap.ico</ApplicationIcon>
		<Version>1.1.0.5</Version>
		<FileVersion>1.1.0.5</FileVersion>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<RootNamespace>Orbitstrap</RootNamespace>
		

		<!-- Single File Publishing -->
		<PublishSingleFile>true</PublishSingleFile>
		<SelfContained>true</SelfContained>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>

		<!-- Disable satellite assemblies -->
		<SatelliteResourceLanguages>en-US</SatelliteResourceLanguages>
		<InvariantGlobalization>false</InvariantGlobalization>

		<!-- Optimization -->
		<PublishTrimmed>false</PublishTrimmed>
		<PublishReadyToRun>true</PublishReadyToRun>
		<TieredCompilation>true</TieredCompilation>
		<TieredCompilationQuickJit>true</TieredCompilationQuickJit>
		<TieredPGO>true</TieredPGO>
		
		<!-- Startup Speed -->
		<OptimizeImplicitlyTriggeredBuild>true</OptimizeImplicitlyTriggeredBuild>
		<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
		
		<DebugType>None</DebugType>
		<DebugSymbols>false</DebugSymbols>
		<StartupObject></StartupObject>
		<SupportedOSPlatformVersion>8.0</SupportedOSPlatformVersion>
		<!-- Suppress design-time XAML namespace errors from ProjectReference assemblies -->
		<DisableXamlTypeBackgroundCompilation>true</DisableXamlTypeBackgroundCompilation>
		<XamlDiagnosticLevel>None</XamlDiagnosticLevel>
		<MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);MC3074;MC3004;MC3131;XLS0004</MSBuildWarningsAsMessages>
		<!-- Suppress NuGet package pruning/trim informational warnings -->
		<NoWarn>$(NoWarn);NU1604;NU1701;IL2026;IL2057;CS4014</NoWarn>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
	  <WarningLevel>4</WarningLevel>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
	  <WarningLevel>4</WarningLevel>
	</PropertyGroup>
	

